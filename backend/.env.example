# Database Configuration
# Local SQLite development database (Async)
DATABASE_URL=sqlite+aiosqlite:///./webcraft.db

# Production Supabase PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/dbname

# JWT Security
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
# Access token lifetime (minutes). Keep short; use refresh tokens for longer sessions.
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime (days).
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS: comma-separated list of allowed frontend origins (NO trailing slash).
# In production, include your Vercel domain, e.g.:
# ALLOWED_ORIGINS=https://webcraft.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Services API Keys (Backend Proxy)
# Fill this key with your Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
# Fallback to Claude if needed
ANTHROPIC_API_KEY=your_anthropic_api_key_here
