# Base URL of the backend API. IMPORTANT: it must include the /api path,
# because all backend routes live under /api.
#
# Development: leave this UNSET to use Vite's dev proxy (recommended).
# api.js then defaults to "/api" and Vite forwards it to http://localhost:8000.
# (If you prefer to set it explicitly in dev: VITE_API_URL=http://localhost:8000/api)
#
# Production (e.g. on Vercel): set it to your backend host + /api, no trailing slash:
# VITE_API_URL=https://ooyaann-webcraft-backend.hf.space/api
